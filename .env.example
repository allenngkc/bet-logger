# Copy to .env and fill in. .env is gitignored — never commit real secrets.

DISCORD_TOKEN=                     # Discord bot token
ANTHROPIC_API_KEY=                 # Anthropic API key
ANTHROPIC_MODEL=claude-opus-4-8    # or claude-sonnet-4-6 for lower cost

SPREADSHEET_ID=                    # Google Sheet ID from its URL
WORKSHEET_NAME=Bets                # worksheet/tab name (created if missing)

# Optional: restrict the screenshot flow to one channel. If unset, the bot
# watches every channel it can see. Commands (!help/!summary/...) work anywhere.
BET_CHANNEL_ID=

# Google service account — paste the full JSON on one line (preferred on cloud):
GOOGLE_SERVICE_ACCOUNT_JSON=
# ...or point at a local file instead (local dev only):
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
